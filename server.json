{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.alunsoldantarctica/mail-index",
  "title": "mail-index",
  "description": "Local-first, read-only MCP server for recall over your Gmail: search, contacts, threads, digests.",
  "repository": {
    "url": "https://github.com/alunsoldantarctica/mail-index",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mail-index",
      "version": "1.0.0",
      "runtimeHint": "npx",
      "runtimeArguments": [
        { "type": "named", "name": "-y" },
        { "type": "named", "name": "-p", "value": "mail-index" },
        { "type": "positional", "value": "mail-index-mcp" }
      ],
      "transport": { "type": "stdio" }
    }
  ]
}
