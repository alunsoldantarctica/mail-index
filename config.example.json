{
  "accounts": {
    "acct-a": {
      "adapter": "gws",
      "configDir": "~/.config/gws-acct-a",
      "syncPolicy": {
        "since": "1mo",
        "includeSent": true
      }
    },
    "acct-b": {
      "adapter": "gws",
      "configDir": "~/.config/gws-acct-b",
      "syncPolicy": {
        "query": "from:you@example.com",
        "limit": 5000,
        "includeSent": false
      }
    },
    "personal": {
      "adapter": "gog",
      "account": "you@gmail.com",
      "syncPolicy": {
        "since": "1mo",
        "includeSent": true
      }
    }
  }
}
