{
  "name": "mail-index",
  "version": "1.2.1",
  "mcpName": "io.github.alunsoldantarctica/mail-index",
  "description": "A local, agent-queryable mail intelligence layer — progressive mailbox index + MCP server for AI agents.",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "license": "MIT",
  "author": "Unsold Group (https://unsold.group/al)",
  "homepage": "https://github.com/alunsoldantarctica/mail-index#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alunsoldantarctica/mail-index.git"
  },
  "bugs": {
    "url": "https://github.com/alunsoldantarctica/mail-index/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "email",
    "gmail",
    "ai-agents",
    "claude",
    "local-first",
    "sqlite",
    "fts5",
    "rag",
    "mail-index"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "mail-index": "bin/cli.mjs",
    "mail-index-mcp": "bin/mcp.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "pretest": "tsc",
    "test": "node --disable-warning=ExperimentalWarning --test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "bundle": "tsc && node scripts/bundle.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "graphology-types": "^0.24.8",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0"
  }
}
