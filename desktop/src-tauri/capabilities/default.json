{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Allow the onboarding shell to spawn the mail-index, gog, and brew CLIs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "mail-index",
          "cmd": "mail-index",
          "args": true
        },
        {
          "name": "gog",
          "cmd": "gog",
          "args": true
        },
        {
          "name": "brew",
          "cmd": "brew",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "mail-index",
          "cmd": "mail-index",
          "args": true
        },
        {
          "name": "gog",
          "cmd": "gog",
          "args": true
        },
        {
          "name": "brew",
          "cmd": "brew",
          "args": true
        }
      ]
    }
  ]
}
