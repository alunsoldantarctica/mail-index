{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mail-index",
  "version": "1.0.0",
  "identifier": "group.unsold.mailindex",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "mail-index",
        "width": 720,
        "height": 560,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/google-oauth-client.json": "resources/google-oauth-client.json"
    },
    "category": "Productivity",
    "shortDescription": "Local mail search for your AI assistant.",
    "longDescription": "mail-index walks you through indexing your Gmail locally so AI assistants can search it privately, on your machine.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "entitlements": null,
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 540, "y": 220 },
        "windowSize": { "width": 720, "height": 420 }
      }
    },
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
